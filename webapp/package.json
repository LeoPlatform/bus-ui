{
  "name": "botmon",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "create-env-test-cup": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env test --bus cup",
    "create-env-staging-cup": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env staging --bus cup",
    "create-env-prod-cup": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env prod --bus cup",
    "create-env-test-chub": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env test --bus chub",
    "create-env-staging-chub": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env staging --bus chub",
    "create-env-prod-chub": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env prod --bus chub",
    "create-env-test-stream": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env test --bus stream",
    "create-env-staging-stream": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env staging --bus stream",
    "create-env-prod-stream": "tsx scripts/create-env.ts --configLocation ./providers.config.json --env prod --bus stream"
  },
